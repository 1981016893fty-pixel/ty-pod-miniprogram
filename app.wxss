/* ============================================
   TY Pod — 全局样式
   外壳：经典 iPod Classic 银白铝合金
   屏幕内：iOS 26 液态玻璃 · 浅霓虹色（淡雅）
   ============================================ */

/* ---------- 基础重置 ---------- */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
  user-select: none;
  -webkit-user-select: none;
  /* 深色背景 — 让金属机身极致浮出 */
  background: linear-gradient(155deg, #14161c 0%, #1c1f26 25%, #242830 50%, #1a1d24 75%, #101218 100%);
}

/* ===========================================
   主容器 — 居中显示
   =========================================== */
.ipod-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

/* ===========================================
   iPod 机身 — 水滴形 3D 凸面
   中心高亮凸起 + 四圆角拉伸 + 边缘微光环收边
   视觉立体感强，同时边缘始终可见
   =========================================== */
.ipod-body {
  position: relative;
  z-index: 2;
  width: 80%;
  aspect-ratio: 5 / 6;
  border-radius: 80rpx;
  overflow: visible;
  box-sizing: border-box;
  /* ═══ 水滴形阴影：外悬浮 + 边缘亮环收边 + 弧面体积 ═══ */
  box-shadow:
    /* ① 外投影 — 机身悬浮 */
    0 44rpx 120rpx rgba(0,0,0,0.55),
    /* ② 边缘亮环 — 水滴收边，任何背景都可见 */
    inset 0 0 0 3rpx rgba(255,255,255,0.09),
    /* ③ 顶部高光 — 上弧面受光 */
    inset 0 3rpx 8rpx rgba(255,255,255,0.12),
    /* ④ 底部厚暗面 — 下弧面背光挤出体积 */
    inset 0 -20rpx 16rpx -8rpx rgba(0,0,0,0.42),
    /* ⑤ 左侧弧面渐暗 — 远离光源的体积感 */
    inset 14rpx 0 18rpx -8rpx rgba(0,0,0,0.22);
}

/* ═══ 水滴凸面中心高光 — 模拟水滴最高点的镜面反射 ═══ */
.ipod-body::before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 1;
  border-radius: 80rpx;
  pointer-events: none;
  background:
    /* ① 水滴凸面中心放射高光 — 核心立体来源 */
    radial-gradient(ellipse 62% 50% at 46% 36%,
      rgba(255,255,255,0.17) 0%,
      rgba(255,255,255,0.08) 32%,
      rgba(255,255,255,0.02) 56%,
      transparent 78%),
    /* ② 主光源（左上 140°）— 亮面金属反射 */
    linear-gradient(155deg,
      rgba(255,255,255,0.14) 0%,
      rgba(255,255,255,0.07) 5%,
      transparent 17%,
      transparent 47%,
      rgba(0,0,0,0.05) 66%,
      rgba(0,0,0,0.15) 84%,
      rgba(0,0,0,0.25) 100%),
    /* ③ 顶边菲涅尔高光 + 底边微反弹光 */
    linear-gradient(180deg,
      rgba(255,255,255,0.11) 0%,
      rgba(255,255,255,0.05) 1.5%,
      transparent 5%,
      transparent 90%,
      rgba(255,255,255,0.04) 96%,
      rgba(255,255,255,0.02) 100%);
}

/* ═══ 水滴曲面轮廓 — 离中心越远越暗，模拟凸面向下弧度 ═══ */
.ipod-body::after {
  content: '';
  position: absolute;
  z-index: 1;
  pointer-events: none;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 80rpx;
  background:
    /* ① 水滴曲面渐暗 — 中心透明 → 四边微暗，立体弧面的核心 */
    radial-gradient(ellipse 82% 70% at 50% 42%,
      transparent 50%,
      rgba(0,0,0,0.02) 66%,
      rgba(0,0,0,0.06) 80%,
      rgba(0,0,0,0.10) 100%),
    /* ② 左侧弧面暗带 — 远离主光源 */
    linear-gradient(100deg,
      rgba(0,0,0,0.16) 0%,
      rgba(0,0,0,0.08) 3%,
      rgba(0,0,0,0.02) 6%,
      transparent 13%,
      transparent 82%,
      rgba(255,255,255,0.02) 92%,
      rgba(255,255,255,0.05) 100%),
    /* ③ 底部边缘暗带 — 圆角底部厚度 */
    linear-gradient(0deg,
      rgba(0,0,0,0.14) 0%,
      rgba(0,0,0,0.05) 3%,
      transparent 8%);
}

/* ═══ 机身金属弧面色 — 7色 2.5D 高对比金属渐变 ═══ */
