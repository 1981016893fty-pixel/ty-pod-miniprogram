/* ============================================
   TY Pod — 全局样式
   外壳：经典 iPod Classic 银白铝合金
   屏幕内：iOS 26 液态玻璃 · 浅霓虹色（淡雅）
   ============================================ */

/* ---------- 基础重置 ---------- */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
  user-select: none;
  -webkit-user-select: none;
  /* 深色背景 — 让金属机身极致浮出 */
  background: linear-gradient(155deg, #1e2028 0%, #2a2d36 25%, #343840 50%, #262932 75%, #1a1c24 100%);
}

/* ===========================================
   主容器 — 居中显示
   =========================================== */
.ipod-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

/* ===========================================
   iPod 机身 — 极限 3D 立体金属
   抛光电镀铝合金：极端高对比弧面 + 物理厚度挤出 + 双层光源
   =========================================== */
.ipod-body {
  position: relative;
  z-index: 2;
  width: 88%;
  height: 0;
  padding-bottom: 120%;
  border-radius: 64rpx;
  overflow: hidden;
  box-sizing: border-box;
  /* ═══ Mac 水滴形边缘 — 液态玻璃折射 + 表面张力凸起 ═══ */
  box-shadow:
    /* — 柔和悬浮投影 — */
    0 30rpx 80rpx rgba(0,0,0,0.40),
    0 12rpx 30rpx rgba(0,0,0,0.25),
    /* ═══ 水滴顶部高光弧 — 几乎无 ═══ */
    inset 0 10rpx 8rpx -2rpx rgba(255,255,255,0.04),
    inset 0 6rpx 4rpx -1rpx rgba(255,255,255,0.02),
    inset 0 3rpx 2rpx rgba(255,255,255,0.01),
    /* 顶边外缘 — 细折射线 */
    inset 0 1rpx 0 rgba(255,255,255,0.06),
    /* 底边 — 水滴底部柔和暗面 */
    inset 0 -8rpx 6rpx -2rpx rgba(0,0,0,0.30),
    inset 0 -5rpx 3rpx -1rpx rgba(0,0,0,0.20),
    inset 0 -2rpx 1rpx rgba(0,0,0,0.12),
    /* 底边外缘 — 水滴底部接触暗线 */
    inset 0 -1rpx 0 rgba(0,0,0,0.15),
    /* 左侧 — 水滴左侧弧面柔和过渡 */
    inset 8rpx 0 10rpx -3rpx rgba(0,0,0,0.18),
    inset 4rpx 0 6rpx -2rpx rgba(0,0,0,0.10),
    inset 2rpx 0 2rpx rgba(255,255,255,0.10),
    /* 右侧 — 水滴右侧弧面反光 */
    inset -8rpx 0 10rpx -3rpx rgba(255,255,255,0.14),
    inset -4rpx 0 6rpx -2rpx rgba(255,255,255,0.08),
    inset -2rpx 0 2rpx rgba(255,255,255,0.06);
}

/* ═══ 水滴顶部液态光泽弧 — 模拟水滴表面张力捕获光线 ═══ */
.ipod-body::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  border-radius: 64rpx;
  pointer-events: none;
  background:
    /* ① 顶部水滴光泽 — 几乎无 */
    linear-gradient(180deg,
      rgba(255,255,255,0.04) 0%,
      rgba(255,255,255,0.02) 3%,
      transparent 7%,
      transparent 14%,
      transparent 24%,
      transparent 72%,
      rgba(0,0,0,0.08) 86%,
      rgba(0,0,0,0.16) 96%,
      rgba(0,0,0,0.22) 100%),
    /* ② 底部环境光反弹 — 极弱 */
    linear-gradient(0deg,
      rgba(255,255,255,0.04) 0%,
      rgba(255,255,255,0.02) 5%,
      transparent 15%);
}

/* ═══ 水滴左侧折射光弧 + 边缘液体光泽 ═══ */
.ipod-body::after {
  content: '';
  position: absolute;
  z-index: 1;
  pointer-events: none;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 64rpx;
  background:
    /* 左侧水滴弧面折射 — 几乎无 */
    linear-gradient(95deg,
      rgba(255,255,255,0.02) 0%,
      transparent 3%,
      transparent 10%,
      transparent 20%);
}

