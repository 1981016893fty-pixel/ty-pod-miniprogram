/* ===========================================
   屏幕 — 浅色液态玻璃（浓郁霓虹渐变）
   =========================================== */
/* ═══════════════════════════════════════
   屏幕外壳 — 金属面板中 CNC 铣削出的屏幕槽
   三层结构：① 金属边框（border + 倒角高光/阴影）
             ② 屏幕槽凹陷（::before 内阴影）
             ③ 屏幕内面板（ipod-screen-inner 深阴影）
   ═══════════════════════════════════════ */
.ipod-screen {
  position: absolute;
  top: 5%;
  left: 7%;
  right: 7%;
  height: 43%;
  /* ⭐ 修复耳机线穿过屏幕区域问题：屏幕 z-index 必须 > earpods-plug 的 11，
     这样 earpods-plug 在屏幕所在的水平位置（right:120rpx 范围内）会被屏幕遮住，
     实现"线从屏幕右边缘底部下垂"+"金属头没入机身"+"底座仅底部露出"的效果 */
  z-index: 12;
  /* 屏幕底色 — 黑暗屏幕面板，区别于金属机身的冰冷深色调 */
  background: #17131e;
  border-radius: 10rpx;
  overflow: hidden;
  transition: background 0.7s ease-out;
  /* ═══ 金属边框 + CNC 切削倒角 ═══ */
  /* 第一步：金属边框本身 — 与机身同色系的铝合金边框 */
  border: 3rpx solid rgba(175,165,190,0.62);
  /* 第二步：边框的 3D 光影 — CNC 倒角切削面 */
  box-shadow:
    /* ① 框体外投影 — 屏幕模块在机身上方的微投影 */
    0 3rpx 12rpx rgba(0,0,0,0.20),
    /* ② 上倒角高光 — 顶部切削面迎着光源，亮白反光 */
    inset 0 2rpx 3rpx rgba(255,255,255,0.38),
    /* ③ 下倒角暗面 — 底部切削面背光，深色 */
    inset 0 -3rpx 4rpx rgba(0,0,0,0.32),
    /* ④ 左倒角暗面 — 左侧远离光源 */
    inset 3rpx 0 4rpx -1rpx rgba(0,0,0,0.16),
    /* ⑤ 右倒角微反光 — 右侧次光源 */
    inset -3rpx 0 4rpx -1rpx rgba(255,255,255,0.06);
}

/* ===========================================
   凯斯哈林涂鸦背景层（页面级 — 在 iPod 机身后面）
   =========================================== */
.kh-bg-layer {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
  overflow: hidden;
}
.kh-bg-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(1.05);
  /* filter removed for mobile compat */
  transition:
    opacity 3s ease-in-out,
    transform 3s ease-in-out;
}
.kh-bg-img.active {
  opacity: 1;
  transform: scale(1);
  /* filter removed for mobile compat */
}

/* ═══ 2.5D 背景表面渐变 — 底部模拟桌面/地面 ═══ */
.kh-bg-layer::after {
  content: '';
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 1;
  pointer-events: none;
  background:
    /* 由上到下：深空 → 浅色表面 → 暗角压底 */
    linear-gradient(180deg,
      rgba(0,0,0,0.15) 0%,
      rgba(0,0,0,0.04) 18%,
      transparent 40%,
      rgba(0,0,0,0.06) 68%,
      rgba(0,0,0,0.16) 84%,
      rgba(0,0,0,0.28) 100%);
}

/* ═══ 2.5D 地面投影 — 机身接触阴影，建立「放置在表面」的错觉 ═══ */
.ground-shadow {
  position: fixed;
  bottom: 6%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  width: 76%;
  height: 12%;
  border-radius: 50%;
  pointer-events: none;
  background: radial-gradient(ellipse 100% 60% at 50% 50%,
    rgba(0,0,0,0.42) 0%,
    rgba(0,0,0,0.28) 24%,
    rgba(0,0,0,0.12) 50%,
    transparent 78%);
}

/* ═══ 屏幕槽内壁阴影 — 屏幕玻璃在金属槽内的凹陷感 ═══ */
.ipod-screen::before {
  content: '';
  position: absolute;
  top: 2rpx; right: 2rpx; bottom: 2rpx; left: 2rpx;
  z-index: 3;
  pointer-events: none;
  border-radius: 8rpx;
  /* 四边向内凹陷的深槽阴影 — 顶部最亮（光源照进槽内）、底部最暗 */
  box-shadow:
    inset 0 3rpx 6rpx rgba(0,0,0,0.45),
    inset 0 -5rpx 8rpx rgba(0,0,0,0.55),
    inset 5rpx 0 6rpx -2rpx rgba(0,0,0,0.30),
    inset -5rpx 0 6rpx -2rpx rgba(0,0,0,0.30);
}

/* ═══ 屏幕玻璃表面反射 — 极微小的高光条模拟玻璃镜面 ═══ */
.ipod-screen::after {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 4;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    /* 左上角玻璃镜面高光 — 一条细窄的斜向反射带 */
    linear-gradient(140deg,
      rgba(255,255,255,0.07) 0%,
      rgba(255,255,255,0.04) 3%,
      transparent 8%),
    /* 顶边极细高光线 — 金属框与玻璃交接处的反光 */
    linear-gradient(180deg,
      rgba(255,255,255,0.05) 0%,
      transparent 4rpx);
}

/* ═══ 屏幕内面板 — 处于金属槽深处的玻璃显示屏 ═══ */
.ipod-screen-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 6rpx 12rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
  overflow: hidden;
  transition: opacity 0.7s ease-out;
  /* 屏幕面板基底 — 暗面 + 微弱中心提亮 */
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(140,120,170,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
  /* 屏幕面板嵌入金属槽的深阴影 — 四周向中心渐变，中心亮、边缘暗 */
  box-shadow:
    /* ① 上沿 — 金属顶框遮挡，屏幕顶部最暗 */
    inset 0 5rpx 10rpx rgba(0,0,0,0.50),
    /* ② 下沿 — 底框阴影 */
    inset 0 -5rpx 10rpx rgba(0,0,0,0.45),
    /* ③ 左沿 */
    inset 6rpx 0 10rpx -3rpx rgba(0,0,0,0.35),
    /* ④ 右沿 */
    inset -6rpx 0 10rpx -3rpx rgba(0,0,0,0.35);
}

/* ═══ 屏幕颜色 — 跟随机身颜色的金属边框 + 微弱屏幕底色 ═══ */
/* silver 保持默认，不覆盖 */

.ipod-body.theme-black .ipod-screen {
  border-color: rgba(80,80,90,0.65);
}
.ipod-body.theme-black .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(80,80,100,0.10) 0%, transparent 70%),
    rgba(25,22,32,0.50);
}

.ipod-body.theme-orange .ipod-screen {
  border-color: rgba(180,120,70,0.60);
}
.ipod-body.theme-orange .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(220,150,60,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
}

.ipod-body.theme-cobalt .ipod-screen {
  border-color: rgba(100,130,180,0.58);
}
.ipod-body.theme-cobalt .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(80,140,210,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
}

.ipod-body.theme-taro .ipod-screen {
  border-color: rgba(150,120,180,0.60);
}
.ipod-body.theme-taro .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(140,100,200,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
}

.ipod-body.theme-pink .ipod-screen {
  border-color: rgba(190,120,150,0.58);
}
.ipod-body.theme-pink .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(220,120,160,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
}

.ipod-body.theme-citrus .ipod-screen {
  border-color: rgba(160,150,80,0.58);
}
.ipod-body.theme-citrus .ipod-screen-inner {
  background:
    radial-gradient(ellipse 80% 60% at 50% 45%, rgba(200,180,60,0.10) 0%, transparent 70%),
    rgba(30,26,38,0.50);
}

/* ⭐ 色块流动 ① — 极微弱紫色光晕漂移（嵌入屏幕内微环境光） */
.ipod-screen-inner::before {
  content: '';
  position: absolute;
  top: -20%; right: -20%; bottom: -20%; left: -20%;
  z-index: 0;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    radial-gradient(ellipse 70% 60% at 30% 30%, rgba(178,140,248,0.42) 0%, transparent 58%);
  animation: blobDriftPurple 8s ease-in-out infinite;
}

/* ⭐ 色块流动 ② — 青绿色光晕反向漂移 */
.ipod-screen-inner::after {
  content: '';
  position: absolute;
  top: -20%; right: -20%; bottom: -20%; left: -20%;
  z-index: 0;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    radial-gradient(ellipse 65% 55% at 70% 70%, rgba(0,220,180,0.36) 0%, transparent 52%);
  animation: blobDriftPink 10s ease-in-out infinite;
}

/* ⭐ 色块流动 ③ — 琥珀色光晕斜向漂移 */
.neon-blob-extra {
  position: absolute;
  top: -20%; right: -20%; bottom: -20%; left: -20%;
  z-index: 0;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    radial-gradient(ellipse 60% 50% at 60% 40%, rgba(255,130,30,0.34) 0%, transparent 52%);
  animation: blobDriftAmber 12s ease-in-out infinite;
}

/* ⭐ 色块流动 ④ — 深紫光晕反向斜向漂移 */
.neon-blob-deep {
  position: absolute;
  top: -20%; right: -20%; bottom: -20%; left: -20%;
  z-index: 0;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    radial-gradient(ellipse 68% 58% at 80% 25%, rgba(80,55,210,0.34) 0%, transparent 54%);
  animation: blobDriftDeep 14s ease-in-out infinite;
}

/* ⭐ Cover Flow 全屏霓虹模式 — 背景铺满整个屏幕 */
.ipod-screen-inner.neon-fullscreen {
  padding: 0;
  background:
    radial-gradient(ellipse 70% 80% at 18% 55%, rgba(130,80,220,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 60% 75% at 82% 50%, rgba(0,200,230,0.16) 0%, transparent 62%),
    radial-gradient(ellipse 55% 50% at 50% 85%, rgba(220,60,160,0.13) 0%, transparent 65%),
    linear-gradient(180deg, #161620 0%, #181822 40%, #161820 100%);
}
.ipod-screen-inner.neon-fullscreen::before,
.ipod-screen-inner.neon-fullscreen::after,
.ipod-screen-inner.neon-fullscreen .neon-blob-extra,
.ipod-screen-inner.neon-fullscreen .neon-blob-deep {
  display: none;
}
.ipod-screen-inner.neon-fullscreen .ipod-header {
  padding: 12rpx 16rpx 14rpx;
}
.ipod-screen-inner.neon-fullscreen .ipod-coverflow {
  background: none;
  border-radius: 0;
}
.ipod-screen-inner.neon-fullscreen .mini-bar {
  padding-left: 16rpx;
  padding-right: 16rpx;
}
.ipod-screen-inner.neon-fullscreen .ipod-coverflow-label {
  padding-left: 16rpx;
  padding-right: 16rpx;
}

/* ⭐ Cover Flow 流动色块 — 熔岩灯霓虹 */
.neon-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.neon-blob-1 {
  width: 400rpx; height: 400rpx;
  top: 10%; left: -8%;
  background: radial-gradient(circle, rgba(140,70,230,0.22) 0%, rgba(100,50,200,0.08) 40%, transparent 65%);
  animation: cfBlobA 7s ease-in-out infinite;
}
.neon-blob-2 {
  width: 360rpx; height: 360rpx;
  top: 45%; right: -6%;
  background: radial-gradient(circle, rgba(0,200,235,0.20) 0%, rgba(0,150,210,0.06) 40%, transparent 65%);
  animation: cfBlobB 9s ease-in-out infinite;
}
.neon-blob-3 {
  width: 380rpx; height: 380rpx;
  bottom: 5%; left: 25%;
  background: radial-gradient(circle, rgba(230,55,150,0.18) 0%, rgba(200,40,120,0.06) 40%, transparent 65%);
  animation: cfBlobC 8s ease-in-out infinite;
}
.neon-blob-4 {
  width: 280rpx; height: 280rpx;
  top: 30%; left: 40%;
  background: radial-gradient(circle, rgba(80,180,255,0.16) 0%, rgba(50,130,220,0.05) 40%, transparent 65%);
  animation: cfBlobD 6s ease-in-out infinite;
}
.neon-blob-5 {
  width: 320rpx; height: 320rpx;
  top: 60%; left: 5%;
  background: radial-gradient(circle, rgba(180,30,80,0.20) 0%, rgba(140,20,60,0.06) 40%, transparent 65%);
  animation: cfBlobE 10s ease-in-out infinite;
}

@keyframes cfBlobA {
  0%, 100% { opacity: 0.6; transform: translate(0,0) scale(1); }
  25%      { opacity: 0.9; transform: translate(60%, -30%) scale(1.35); }
  50%      { opacity: 0.45; transform: translate(-20%, 50%) scale(0.8); }
  75%      { opacity: 0.75; transform: translate(30%, 20%) scale(1.15); }
}
@keyframes cfBlobB {
  0%, 100% { opacity: 0.55; transform: translate(0,0) scale(1); }
  30%      { opacity: 0.85; transform: translate(-50%, 25%) scale(1.3); }
  60%      { opacity: 0.4; transform: translate(20%, -40%) scale(0.75); }
  80%      { opacity: 0.7; transform: translate(-15%, 10%) scale(1.1); }
}
@keyframes cfBlobC {
  0%, 100% { opacity: 0.5; transform: translate(0,0) scale(1); }
  20%      { opacity: 0.8; transform: translate(40%, -35%) scale(1.25); }
  50%      { opacity: 0.35; transform: translate(-30%, -15%) scale(0.85); }
  75%      { opacity: 0.65; transform: translate(15%, 25%) scale(1.2); }
}
@keyframes cfBlobD {
  0%, 100% { opacity: 0.4; transform: translate(0,0) scale(1); }
  33%      { opacity: 0.7; transform: translate(-40%, 40%) scale(1.3); }
  66%      { opacity: 0.3; transform: translate(35%, -20%) scale(0.7); }
}
@keyframes cfBlobE {
  0%, 100% { opacity: 0.5; transform: translate(0,0) scale(1); }
  25%      { opacity: 0.8; transform: translate(50%, -30%) scale(1.25); }
  50%      { opacity: 0.35; transform: translate(-25%, 20%) scale(0.8); }
  75%      { opacity: 0.65; transform: translate(20%, -35%) scale(1.15); }
}
@keyframes cfBlobF {
  0%, 100% { opacity: 0.45; transform: translate(0,0) scale(1); }
  30%      { opacity: 0.75; transform: translate(-45%, 35%) scale(1.2); }
  60%      { opacity: 0.3; transform: translate(25%, -25%) scale(0.85); }
  80%      { opacity: 0.6; transform: translate(-10%, 15%) scale(1.1); }
}

/* 屏幕关闭状态 */
.ipod-screen.backlight-off {
  background: #222 !important;
  box-shadow: none !important;
}
.ipod-screen.backlight-off::before,
.ipod-screen.backlight-off::after {
  display: none;
}
.ipod-screen.backlight-off .ipod-screen-inner {
  opacity: 0;
}
/* iPhone 风格全天候显示 (Always-On Display)
   — 屏幕没插入耳机前变暗（不显示额外时钟/日期）
   — **关键**：完全不用 filter。filter 的色彩矩阵会吞掉多色渐变让屏幕"塌"成灰。
     用 opacity 调暗内层 — 屏幕外层保持不透明（无 filter 无 opacity），背景机身不会透过来。
*/
.ipod-screen-inner {
  /* 屏幕从息屏到点亮时：内层内容亮度平滑过渡 */
  transition: opacity 1.5s ease, background 1.5s ease;
}
.ipod-screen.always-on .ipod-screen-inner {
  /* 内层内容压暗到 0.5 — 暗但能看清，**色相和饱和度完全不变** */
  opacity: 0.5;
  /* AOD 态：去掉 inner 自带的半透明背景（rgba(30,26,38,0.50)），
     避免它和底层 #17131e 屏幕底色混合出灰雾感 */
  background: transparent;
  pointer-events: none;
}
/* AOD 态隐藏装饰性霓虹色块（它们在暗态下会和底色混合成灰雾） */
.ipod-screen.always-on .neon-blob-extra,
.ipod-screen.always-on .neon-blob-deep {
  display: none;
}
/* backlight-off 的 opacity:0 优先级始终低于 .always-on 的 0.5 — 用相同特异性
   把 AOD 态 opacity 写死到内层，避免 backlight-off 把 always-on 覆盖 */
.ipod-screen.backlight-off.always-on .ipod-screen-inner {
  opacity: 0.5;
  background: transparent;
  pointer-events: none;
}
/* AOD 态覆盖外层：屏幕外层必须保持不透明 + 保留原彩色背景，不能让 #222 灰底或 0.18 透出来 */
.ipod-screen.always-on {
  background: inherit;
  box-shadow: inherit;
}
.ipod-screen.always-on::before,
.ipod-screen.always-on::after {
  display: block;
}

/* ===========================================
   EarPods 耳机插头 + 插入动画 + 震动
   — 竖直插入机身底部右侧边缘
   — 插入完成后底座紧贴外壳边缘，金属头没入机身
   =========================================== */

/* — 插件容器：机身底部右侧，线从底部边缘自然下垂 — */
.earpods-plug {
  position: absolute;
  z-index: 11;
  right: 120rpx;
  bottom: -800rpx;
  width: 50rpx;
  height: 700rpx;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}
/* 等待态：插头在机身下方可见，准备插入 */
.earpods-plug.waiting {
  opacity: 1;
}
/* 插入态：向上滑入，底座贴合机身底部边缘 */
.earpods-plug.inserting {
  opacity: 1;
  animation: earpodsInsert 2.8s cubic-bezier(0.34, 1.1, 0.5, 1) forwards;
}
.earpods-plug.inserted,
.earpods-plug.plugged {
  bottom: -694rpx;
  opacity: 1;
}

/* — 3.5mm 金属插头 — 在容器上方，插入机身，跟随插入进度实时消失 — */
.earpods-jack {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  /* 修复：让金属头在最终位置完全没入机身内（top: -42rpx = 金属头高度） */
  top: -42rpx;
  width: 14rpx;
  height: 42rpx;
  border-radius: 7rpx 7rpx 3rpx 3rpx;
  background: linear-gradient(90deg,
    #a8a8a8 0%, #d0d0d0 18%, #f0f0f0 42%, #e0e0e0 62%, #c0c0c0 82%, #a0a0a0 100%);
  box-shadow:
    1rpx 1rpx 4rpx rgba(0,0,0,0.25),
    inset -2rpx 0 3rpx rgba(255,255,255,0.55),
    inset 2rpx 0 3rpx rgba(0,0,0,0.10);
  z-index: 2;
}
/* 插入态：金属头从顶部开始被裁剪，跟随插入进度实时消失 */
.earpods-plug.inserting .earpods-jack {
  animation: jackDisappear 2.8s cubic-bezier(0.34, 1.1, 0.5, 1) forwards;
}
/* 插入完成后：金属头完全裁剪 */
.earpods-plug.inserted .earpods-jack,
.earpods-plug.plugged .earpods-jack {
  clip-path: inset(100% 0 0 0);
}
/* TRRS 绝缘环 — 3 道黑色环 */
.earpods-ring {
  position: absolute;
  left: 0;
  width: 14rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #1c1c1c;
}
.earpods-ring:nth-child(1) { top: 8rpx; }
.earpods-ring:nth-child(2) { top: 17rpx; }
.earpods-ring:nth-child(3) { top: 26rpx; }

/* — 白色 EarPods 连接器底座 — 居中容器，让线从底座正中央接出 — */
.earpods-base {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 0;
  width: 22rpx;
  height: 50rpx;
  border-radius: 11rpx 11rpx 7rpx 7rpx;
  background: linear-gradient(90deg,
    #d0d0d0 0%, #f5f5f5 20%, #ffffff 45%, #f2f2f2 70%, #c8c8c8 100%);
  box-shadow:
    1rpx 2rpx 6rpx rgba(0,0,0,0.18),
    inset -2rpx 0 3rpx rgba(255,255,255,0.85),
    inset 2rpx 0 3rpx rgba(0,0,0,0.06);
  z-index: 3;
}
/* 底座内部高光 */
.earpods-base::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 5rpx;
  width: 4rpx;
  height: 38rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 2rpx;
}

/* — 超长白色耳机线 — 从底座正中央接出，带圆柱质感和自然弧度 — */
.earpods-cable {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 38rpx;
  width: 9rpx;
  height: 580rpx;
  border-radius: 4.5rpx;
  background: linear-gradient(90deg,
    #b8b8b8 0%, #d8d8d8 15%, #f4f4f4 35%, #ffffff 50%, #f0f0f0 65%, #d0d0d0 85%, #a8a8a8 100%);
  box-shadow:
    1rpx 1rpx 4rpx rgba(0,0,0,0.10),
    inset -1.5rpx 0 2rpx rgba(0,0,0,0.08),
    inset 1.5rpx 0 2rpx rgba(255,255,255,0.95);
  z-index: 1;
}
/* 线材与底座的连接处 — 肋状应力缓冲套（strain relief） */
.earpods-cable::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 16rpx;
  border-radius: 4rpx 4rpx 3rpx 3rpx;
  background: repeating-linear-gradient(180deg,
    #c8c8c8 0rpx, #e8e8e8 2rpx, #f6f6f6 3rpx, #e0e0e0 5rpx, #d0d0d0 6rpx, #ececec 8rpx);
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.12), inset 0 1rpx 1rpx rgba(255,255,255,0.6);
}
/* 线身中段微弧 — 模拟自然下垂 */
.earpods-cable::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg,
    transparent 0%, rgba(255,255,255,0.12) 40%, rgba(255,255,255,0.20) 50%, rgba(255,255,255,0.12) 60%, transparent 100%);
  pointer-events: none;
}

/* ===========================================
   @keyframes
   =========================================== */

@keyframes earpodsInsert {
  0%   { bottom: -800rpx; }
  100% { bottom: -694rpx; }
}

/* 金属插头跟随插入进度从顶部实时裁剪消失 — 起始与 waiting 阶段一致（完全可见），
   插入过程中从顶部连续裁剪至完全消失，无突变 */
@keyframes jackDisappear {
  0%        { clip-path: inset(0 0 0 0); }       /* 起始：完全可见（与 waiting 一致） */
  100%      { clip-path: inset(100% 0 0 0); }    /* 结束：完全裁剪消失 */
}

/* ===========================================
   右侧滚动位置指示条
   =========================================== */
.ipod-scrollbar-track {
  position: absolute;
  top: 40rpx;
  bottom: 40rpx;
  right: 4rpx;
  width: 4rpx;
  z-index: 10;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.25s ease;
}
.ipod-scrollbar-track.visible {
  opacity: 1;
}
.ipod-scrollbar-thumb {
  position: absolute;
  left: 0;
  width: 100%;
  border-radius: 4rpx;
  background: rgba(80,80,100,0.45);
}

/* ===========================================
   标题栏（屏幕内部）
   =========================================== */
.ipod-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 8rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
  background: transparent;
}
/* 标题移到左边，金色烫印效果 — 与 Cover Flow 深色背景上一致 */
.ipod-header-title {
  flex: 1;
  text-align: left;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  /* 实色金色 — 在浅/深背景上均与 Cover Flow 一致 */
  color: rgba(232,195,110,0.82);
  -webkit-text-fill-color: rgba(232,195,110,0.82);
  -webkit-text-stroke: 0.5rpx rgba(255,220,140,0.30);
  text-shadow: 0 0 6rpx rgba(255,200,100,0.18);
  /* filter drop-shadow removed for mobile compat */
}
.ipod-header-back-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  -webkit-tap-highlight-color: transparent;
}
.ipod-header-back-wrap:active {
  background: rgba(255,255,255,0.18);
}
.ipod-header-back-arrow {
  font-size: 40rpx;
  font-weight: 400;
  color: rgba(255,255,255,0.82);
  line-height: 1;
  margin-left: -2rpx;
}
.ipod-header-back-placeholder {
  width: 56rpx;
  flex-shrink: 0;
}
/* 电池图标 — 液态玻璃 */
.battery-icon {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 3rpx 5rpx;
  border: 0.5rpx solid rgba(255,255,255,0.12);
  border-radius: 5rpx;
  position: relative;
  background: transparent;
  box-shadow: none;
}
.battery-icon .cap {
  position: absolute;
  right: -5rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 10rpx;
  background: rgba(255,255,255,0.10);
  border-radius: 0 3rpx 3rpx 0;
}
.battery-icon .bar {
  width: 4rpx;
  height: 16rpx;
  background: rgba(180,200,255,0.35);
  border-radius: 2rpx;
  box-shadow: none;
}

/* ===========================================
   菜单列表
   =========================================== */
.ipod-menu {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.ipod-menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 14rpx;
  margin: 2rpx 0;
  border-radius: 10rpx;
  transition: opacity 0.22s, background 0.22s, color 0.22s, transform 0.22s;
  background: transparent;
}
/* 高亮条 — 液态玻璃浮层卡片 */
.ipod-menu-item.active {
  /* backdrop-filter 已移除，用不透明背景替代 */
  background:
    linear-gradient(175deg,
      rgba(178,140,248,0.45) 0%,
      rgba(160,120,235,0.38) 25%,
      rgba(210,125,205,0.35) 50%,
      rgba(255,108,172,0.32) 70%,
      rgba(178,140,248,0.40) 100%);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.45),
    inset 0 -1rpx 1rpx rgba(20,10,40,0.10),
    0 2rpx 10rpx rgba(178,140,248,0.25);
  border: 0.5rpx solid rgba(255,255,255,0.30);
}
.ipod-menu-item-label {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}
.ipod-menu-item-arrow {
  color: rgba(255,255,255,0.55);
  font-size: 22rpx;
  font-weight: 300;
}

/* ===========================================
   Mini 播放条 —— 屏幕内底部，可点击进入 Now Playing
   触发条件：playSong 存在且不在 Now Playing 页面
   =========================================== */
.mini-bar {
  display: flex;
  align-items: center;
  padding: 8rpx 0 0;
  border-top: 0.5rpx solid rgba(255,255,255,0.20);
  flex-shrink: 0;
  /* 入场动画初始态 */
  opacity: 0;
  transform: translateY(-12rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.mini-bar.mini-bar-enter {
  opacity: 1;
  transform: translateY(0);
}
.mini-bar.mini-bar-hover {
  opacity: 0.75;
  transition: opacity 0.12s ease;
}

.mini-bar-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  overflow: hidden;
}
.mini-bar-title {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mini-bar-artist {
  font-size: 16rpx;
  color: rgba(255,255,255,0.55);
  line-height: 1.2;
  margin-top: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===========================================
   搜索
   =========================================== */
.ipod-search-box {
  display: flex;
  gap: 0;
  padding: 8rpx 0 12rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  overflow: hidden;
}
.ipod-search-box input {
  flex: 1;
  height: 50rpx;
  background: rgba(255,255,255,0.14);
  border: 0.5rpx solid rgba(255,255,255,0.30);
  border-right: none;
  border-radius: 10rpx 0 0 10rpx;
  padding: 0 14rpx;
  color: #ffffff;
  font-size: 22rpx;
  text-shadow: none;
  box-shadow:
    inset 0 1rpx 0.5rpx rgba(255,255,255,0.35),
    inset 0 -1rpx 2rpx rgba(20,10,40,0.05);
}
.ipod-search-box input::placeholder {
  color: rgba(255,255,255,0.45);
}
/* 搜索按钮 — 液态玻璃 */
.ipod-search-btn {
  width: 76rpx;
  height: 50rpx;
  background: linear-gradient(135deg, rgba(178,140,248,0.90) 0%, rgba(255,108,172,0.78) 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 0 10rpx 10rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 0.5rpx solid rgba(255,255,255,0.30);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.45),
    inset 0 -1rpx 1rpx rgba(20,10,40,0.10),
    0 0 12rpx rgba(178,140,248,0.20);
}

/* 搜索空状态 */
.ipod-search-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  opacity: 0.7;
}
.ipod-search-empty-icon {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx solid rgba(255,255,255,0.20);
  border-radius: 50%;
  position: relative;
}
.ipod-search-empty-icon::after {
  content: '';
  position: absolute;
  right: -6rpx;
  bottom: -4rpx;
  width: 22rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.20);
  border-radius: 3rpx;
  transform: rotate(45deg);
}
.ipod-search-empty-text {
  color: rgba(255,255,255,0.48);
  font-size: 20rpx;
}
.ipod-search-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.15);
  border-top-color: rgba(178,140,248,0.85);
  border-radius: 50%;
  animation: ipod-search-spin 0.8s linear infinite;
}
@keyframes ipod-search-spin {
  to { transform: rotate(360deg); }
}
.ipod-search-retry-btn {
  margin-top: 8rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, rgba(178,140,248,0.90) 0%, rgba(255,108,172,0.78) 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 30rpx;
  border: 0.5rpx solid rgba(255,255,255,0.30);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.45),
    inset 0 -1rpx 1rpx rgba(20,10,40,0.10);
}

/* 搜索结果项 */
.ipod-search-item {
  display: flex;
  align-items: center;
  padding: 8rpx 10rpx;
  border-bottom: 0.5rpx solid rgba(255,255,255,0.12);
  gap: 12rpx;
}
.ipod-search-item .info {
  flex: 1;
  overflow: hidden;
}
.ipod-search-item .name {
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ipod-search-item .artist {
  color: rgba(255,255,255,0.72);
  font-size: 18rpx;
  margin-top: 3rpx;
}
.ipod-search-item .arrow {
  color: rgba(255,255,255,0.55);
  font-size: 22rpx;
  flex-shrink: 0;
  margin-left: auto;
}

/* ===========================================
   正在播放
   =========================================== */
.ipod-player {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 上半区：左专辑 + 右歌词 */
.ipod-player-main {
  flex: 1;
  display: flex;
  gap: 16rpx;
  overflow: hidden;
  min-height: 0;
}

/* 左侧 — 专辑封面 + 歌曲信息 */
.ipod-player-left {
  width: 140rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding-top: 6rpx;
}

/* 右侧 — 歌词滚动 */
.ipod-player-right {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.ipod-player-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.12);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.35),
    inset 0 -1rpx 2rpx rgba(20,10,40,0.08),
    0 4rpx 16rpx rgba(154,128,196,0.14),
    0 0 0 0.5rpx rgba(255,255,255,0.18);
}
.ipod-player-meta {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  overflow: hidden;
  padding: 0 4rpx;
}
.ipod-player-meta .title {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  width: 100%;
}
.ipod-player-meta .artist {
  color: rgba(255,255,255,0.72);
  font-size: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  width: 100%;
}

/* 歌词滚动 */
.ipod-player-lyrics {
  height: 100%;
  padding: 4rpx 0;
}
.ipod-player-lyrics .line {
  color: rgba(255,255,255,0.55);
  font-size: 20rpx;
  line-height: 1.6;
  padding: 2rpx 8rpx;
  text-align: left;
  transition: opacity 0.3s, background 0.3s, color 0.3s, transform 0.3s;
  display: flex;
  flex-direction: column;
}
.ipod-player-lyrics .line .line-text {
  display: block;
}
.ipod-player-lyrics .line .line-tr {
  display: block;
  font-size: 17rpx;
  color: rgba(255,255,255,0.30);
  line-height: 1.5;
  margin-top: 1rpx;
}
/* 空歌词占位 */
.ipod-player-lyrics .line.empty {
  color: rgba(255,255,255,0.38);
  text-align: center;
  padding-top: 40rpx;
  font-size: 18rpx;
}
/* 当前行 — 淡雅高亮 */
.ipod-player-lyrics .line.active {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(178,140,248,0.35), 0 0 5rpx rgba(255,108,172,0.20);
}
.ipod-player-lyrics .line.active .line-tr {
  color: rgba(255,255,255,0.55);
}

/* 进度条 */
.ipod-player-progress {
  flex-shrink: 0;
  padding: 8rpx 16rpx 2rpx;
  width: 100%;
  box-sizing: border-box;
}
.ipod-player-progress-bar {
  height: 4rpx;
  background: rgba(255,255,255,0.10);
  border-radius: 2rpx;
  position: relative;
  margin-bottom: 6rpx;
}
.ipod-player-progress-bar .fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(178,140,248,0.95) 0%, rgba(200,130,220,0.88) 30%, rgba(235,115,185,0.82) 55%, rgba(255,108,172,0.78) 75%, rgba(155,160,230,0.74) 88%, rgba(88,200,245,0.72) 100%);
  border-radius: 2rpx;
  transition: width 0.3s linear;
  box-shadow: 0 0 8rpx rgba(178,140,248,0.22);
}
.ipod-player-progress-bar .dot {
  position: absolute;
  top: -4rpx;
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border: 2rpx solid rgba(178,140,248,0.60);
  border-radius: 50%;
  box-shadow:
    0 2rpx 6rpx rgba(154,128,196,0.24),
    0 0 10rpx rgba(178,140,248,0.22);
  transform: translateX(-50%);
}
.ipod-player-time {
  display: flex;
  justify-content: space-between;
  font-size: 16rpx;
  color: rgba(255,255,255,0.55);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

/* 加载状态 */
.ipod-player-loading {
  flex-shrink: 0;
  padding: 12rpx 0;
  text-align: center;
}
.ipod-player-loading .loading-text {
  font-size: 19rpx;
  color: rgba(255,255,255,0.55);
}

/* 播放控制栏 */
.ipod-player-controls {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 6rpx 0 2rpx;
  flex-shrink: 0;
}
.ipod-player-controls .ctrl {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
}

/* 文字图标（随机/循环/音量） */
.ctrl-glyph {
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1;
}
.ctrl-glyph-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ctrl-glyph-num {
  position: absolute;
  bottom: -2rpx;
  right: -6rpx;
  font-size: 14rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  line-height: 1;
}

/* 播放按钮 — 液态玻璃球体 */
.ipod-player-controls .ctrl.play-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, rgba(178,140,248,0.90) 0%, rgba(255,108,172,0.78) 100%);
  border-radius: 50%;
  color: #ffffff;
  border: 0.5rpx solid rgba(255,255,255,0.30);
  box-shadow:
    inset 0 2rpx 2rpx rgba(255,255,255,0.50),
    inset 0 -2rpx 2rpx rgba(20,10,40,0.12),
    0 3rpx 14rpx rgba(178,140,248,0.35),
    0 0 20rpx rgba(178,140,248,0.18);
}

/* 播放三角形 */
.icon-play {
  width: 0;
  height: 0;
  border-left: 18rpx solid #fff;
  border-top: 11rpx solid transparent;
  border-bottom: 11rpx solid transparent;
  margin-left: 4rpx;
}

/* 暂停 — 两条竖线 */
.icon-pause {
  display: flex;
  gap: 5rpx;
}
.icon-pause-bar {
  width: 5rpx;
  height: 18rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* 上一首 — 竖线 + 左三角 */
.icon-prev {
  display: flex;
  align-items: center;
  gap: 2rpx;
}
.icon-prev-bar {
  width: 3rpx;
  height: 18rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 2rpx;
}
.icon-prev-tri {
  width: 0;
  height: 0;
  border-right: 13rpx solid rgba(255,255,255,0.85);
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

/* 下一首 — 右三角 + 竖线 */
.icon-next {
  display: flex;
  align-items: center;
  gap: 2rpx;
}
.icon-next-tri {
  width: 0;
  height: 0;
  border-left: 13rpx solid rgba(255,255,255,0.85);
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}
.icon-next-bar {
  width: 3rpx;
  height: 18rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 2rpx;
}

/* ===========================================
   音乐列表通用收藏心形
   =========================================== */
.heart {
  font-size: 24rpx;
  flex-shrink: 0;
  padding: 6rpx 8rpx;
  margin-left: 4rpx;
  color: rgba(255,255,255,0.35);
  transition: opacity 0.2s, background 0.2s, color 0.2s, transform 0.2s;
}
.heart.hearted {
  color: #ff6cac;
  text-shadow: 0 0 8rpx rgba(255,108,172,0.45), 0 0 16rpx rgba(255,108,172,0.20);
}
.heart.nowplaying-heart {
  font-size: 28rpx;
  padding: 8rpx;
  margin-top: 6rpx;
}

/* ===========================================
   CoverFlow
   =========================================== */
.ipod-coverflow {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  z-index: 1;
  /* ——— 深色霓虹背景 ——— */
  background:
    /* 左侧霓虹紫光晕 */
    radial-gradient(ellipse 70% 80% at 18% 55%, rgba(130,80,220,0.38) 0%, transparent 65%),
    /* 右侧霓虹青蓝光晕 */
    radial-gradient(ellipse 60% 75% at 82% 50%, rgba(0,200,230,0.28) 0%, transparent 62%),
    /* 中央底部粉红晕 */
    radial-gradient(ellipse 55% 50% at 50% 85%, rgba(220,60,160,0.22) 0%, transparent 65%),
    /* 深色底层 */
    linear-gradient(180deg, #0d0d14 0%, #101018 40%, #0d0f18 100%);
  border-radius: 8rpx;
}
.ipod-coverflow-track {
  display: flex;
  align-items: center;
  position: relative;
  width: 100%;
  height: 320rpx;        /* ⭐ 420→320，卡片缩小后轨道高度也收一收 */
}
.ipod-coverflow-item {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 132rpx;         /* ⭐ 184→132 (-28%)，更紧凑 */
  transition: transform 0.45s cubic-bezier(0.22, 0.12, 0.15, 1.0), opacity 0.35s ease-out;
}
/* ——— 专辑侧脊线（侧视时可见的薄边） ——— */
.ipod-coverflow-item::before {
  content: '';
  position: absolute;
  top: 6rpx;
  bottom: 6rpx;
  left: 50%;
  width: 4rpx;
  transform: translateX(-50%);
  background: linear-gradient(180deg, 
    rgba(200,170,255,0.35) 0%, 
    rgba(140,100,220,0.20) 40%,
    rgba(140,100,220,0.20) 60%,
    rgba(200,170,255,0.35) 100%);
  border-radius: 2rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
  pointer-events: none;
}
/* 非活跃项：显示侧脊线 */
.ipod-coverflow-item:not(.active)::before {
  opacity: 1;
}
/* ——— 翻转卡片容器 ——— */
.ipod-coverflow-card {
  width: 132rpx;          /* ⭐ 184→132，跟 .ipod-coverflow-item 一致 */
  height: 132rpx;
  position: relative;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  transition: transform 0.65s cubic-bezier(0.18, 0.55, 0.35, 1.0);
}
/* ——— 正面（封面+倒影） ——— */
.ipod-coverflow-front {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
/* ——— 背面（专辑信息） ——— */
.ipod-coverflow-back {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform: rotateY(180deg);
  background: linear-gradient(135deg, #1a1530 0%, #141024 50%, #1a1632 100%);
  border-radius: 10rpx;        /* ⭐ 12→10 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 12rpx;         /* ⭐ 20/16→14/12 */
  box-sizing: border-box;
  border: 1rpx solid rgba(160,130,255,0.25);
}
.cf-back-cover-spine {
  width: 4rpx;                  /* ⭐ 6→4 */
  height: 44rpx;                /* ⭐ 60→44 */
  background: linear-gradient(180deg, 
    rgba(180,140,255,0.50) 0%, 
    rgba(120,80,220,0.30) 50%, 
    rgba(80,40,180,0.50) 100%);
  border-radius: 3rpx;
  margin-bottom: 16rpx;
}
.cf-back-name {
  color: #e8e0ff;
  font-size: 18rpx;             /* ⭐ 22→18 */
  font-weight: 600;
  text-align: center;
  line-height: 1.25;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 5rpx;          /* ⭐ 8→5 */
}
.cf-back-artist {
  color: rgba(180,155,240,0.80);
  font-size: 15rpx;             /* ⭐ 18→15 */
  text-align: center;
  margin-bottom: 6rpx;          /* ⭐ 10→6 */
}
.cf-back-count {
  color: rgba(140,120,220,0.55);
  font-size: 13rpx;             /* ⭐ 16→13 */
  margin-top: 3rpx;
}
/* ——— 翻转状态 ——— */
.ipod-coverflow-item.flipped .ipod-coverflow-card {
  transform: rotateY(180deg);
}
.ipod-coverflow-cover {
  width: 132rpx;          /* ⭐ 184→132，跟 item 一致 */
  height: 132rpx;
  border-radius: 10rpx;   /* ⭐ 12→10，小卡片圆角略小 */
  overflow: hidden;
  box-shadow:
    0 4rpx 16rpx rgba(0,0,0,0.65),     /* ⭐ 阴影也按比例收 */
    0 0 0 1rpx rgba(180,140,255,0.20),
    0 0 12rpx rgba(120,80,220,0.25);
}
.ipod-coverflow-cover image {
  width: 100%;
  height: 100%;
  display: block;
}
/* ——— 镜像倒影 ——— */
.ipod-coverflow-reflection {
  width: 132rpx;          /* ⭐ 184→132 */
  height: 80rpx;          /* ⭐ 110→80 */
  overflow: hidden;
  position: relative;
  margin-top: 4rpx;       /* ⭐ 6→4 */
  border-radius: 0 0 6rpx 6rpx;
}
.ipod-coverflow-reflection image {
  width: 100%;
  height: 132rpx;         /* ⭐ 184→132 镜像源高度 */
  display: block;
  transform: scaleY(-1);
}
.ipod-coverflow-reflection-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(13,13,20,0.30) 0%,
    rgba(13,13,20,0.55) 30%,
    rgba(13,13,20,0.78) 62%,
    rgba(13,13,20,0.94) 100%
  );
  pointer-events: none;
}
.ipod-coverflow-item.active .ipod-coverflow-cover {
  box-shadow:
    0 8rpx 28rpx rgba(0,0,0,0.75),     /* ⭐ 10/36→8/28 */
    0 0 0 1rpx rgba(200,160,255,0.40),
    0 0 22rpx rgba(140,80,255,0.50),   /* ⭐ 28→22 */
    0 0 44rpx rgba(0,180,230,0.20);    /* ⭐ 56→44 */
}
.ipod-coverflow-item.active .ipod-coverflow-back {
  box-shadow:
    0 8rpx 28rpx rgba(0,0,0,0.75),
    0 0 0 1rpx rgba(200,160,255,0.40),
    0 0 22rpx rgba(140,80,255,0.50),
    0 0 44rpx rgba(0,180,230,0.20);
}
.ipod-coverflow-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 110;
  text-align: center;
  padding: 12rpx;
  background: linear-gradient(180deg,
    rgba(13,13,20,0) 0%,
    rgba(13,13,20,0.60) 10%,
    rgba(13,13,20,0.82) 100%);
  }
.ipod-coverflow-label .title {
  color: #f0eeff;
  font-size: 23rpx;
  font-weight: 600;
  text-shadow: 0 0 12rpx rgba(160,100,255,0.55);
}
.ipod-coverflow-label .artist {
  color: rgba(180,160,255,0.80);
  font-size: 18rpx;
  margin-top: 2rpx;
}
.ipod-coverflow-label .cf-tap-hint {
  color: rgba(180,160,255,0.50);
  font-size: 14rpx;
  margin-top: 6rpx;
  letter-spacing: 0.5px;
}

/* =============================================
   专辑歌曲列表视图
   ============================================= */
.album-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx 10rpx;
  background: rgba(255,255,255,0.06);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.album-header-cover {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.35);
}
.album-header-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.album-header-name {
  font-size: 21rpx;
  font-weight: 600;
  color: rgba(240,235,255,0.95);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.album-header-count {
  font-size: 16rpx;
  color: rgba(180,160,255,0.65);
}

.album-songs-list {
  height: calc(100% - 110rpx);
}

.ipod-album-song-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 14rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
  gap: 12rpx;
  transition: background 0.15s;
}
.ipod-album-song-item.wheel-highlight {
  background: rgba(130,80,255,0.22);
}
.ipod-album-song-item.playing {
  background: rgba(80,200,180,0.12);
}
.album-song-num {
  font-size: 16rpx;
  color: rgba(180,160,255,0.50);
  width: 36rpx;
  text-align: center;
  flex-shrink: 0;
}
.album-song-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
}
.album-song-name {
  font-size: 21rpx;
  color: rgba(240,235,255,0.92);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.album-song-artist {
  font-size: 16rpx;
  color: rgba(180,160,255,0.60);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ipod-album-song-item .arrow {
  font-size: 18rpx;
  color: rgba(255,255,255,0.30);
  flex-shrink: 0;
}
.album-song-playing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(80,220,180,0.90);
  box-shadow: 0 0 8rpx rgba(80,220,180,0.70);
  animation: playingDotPulse 1s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes playingDotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.7); }
}
.album-songs-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  color: rgba(180,160,255,0.40);
  font-size: 19rpx;
}

/* ===========================================
   热门推荐
   =========================================== */
.ipod-hot-item {
  display: flex;
  align-items: center;
  padding: 10rpx 12rpx;
  border-bottom: 0.5rpx solid rgba(255,255,255,0.12);
  gap: 8rpx;
}
.ipod-hot-item .info { flex: 1; overflow: hidden; }
.ipod-hot-item .name {
  color: #ffffff;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ipod-hot-item .artist {
  color: rgba(255,255,255,0.72);
  font-size: 18rpx;
  margin-top: 3rpx;
}
.ipod-hot-item .arrow { color: rgba(255,255,255,0.55); font-size: 20rpx; }

.hot-rank {
  font-size: 23rpx;
  font-weight: 800;
  width: 34rpx;
  text-align: center;
  flex-shrink: 0;
}
.rank-1 { color: #d06898; }
.rank-2 { color: #9060cc; }
.rank-3 { color: #4db8d8; }
.hot-cover {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.08);
}

.ipod-empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  opacity: 0.6;
}
.ipod-empty-state text {
  color: rgba(255,255,255,0.45);
  font-size: 24rpx;
}
/* 重试按钮 */
.ipod-empty-retry {
  margin-top: 12rpx;
  padding: 14rpx 40rpx;
  background: linear-gradient(135deg, rgba(178,140,248,0.90) 0%, rgba(255,108,172,0.78) 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 30rpx;
  border: 0.5rpx solid rgba(255,255,255,0.30);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.45),
    inset 0 -1rpx 1rpx rgba(20,10,40,0.10),
    0 0 12rpx rgba(178,140,248,0.18);
}

/* ===========================================
   设置
   =========================================== */
.ipod-setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 14rpx;
  border-bottom: 0.5rpx solid rgba(255,255,255,0.12);
  margin: 2rpx 0;
  border-radius: 10rpx;
}
.ipod-setting-item .label {
  color: #ffffff;
  font-size: 23rpx;
}
.ipod-setting-item .value {
  color: rgba(255,255,255,0.72);
  font-size: 21rpx;
}
/* 设置高亮 — 液态玻璃 */
.ipod-setting-item.active {
  /* backdrop-filter 已移除，用不透明背景替代 */
  background:
    linear-gradient(175deg,
      rgba(178,140,248,0.42) 0%,
      rgba(160,120,235,0.36) 25%,
      rgba(210,125,205,0.32) 50%,
      rgba(255,108,172,0.30) 70%,
      rgba(178,140,248,0.38) 100%);
  box-shadow:
    inset 0 1.5rpx 1rpx rgba(255,255,255,0.45),
    inset 0 -1rpx 1rpx rgba(20,10,40,0.10),
    0 2rpx 10rpx rgba(178,140,248,0.25);
  border: 0.5rpx solid rgba(255,255,255,0.30);
}

/* ===========================================
   滚轮 — iPod Click Wheel · 陶瓷嵌入金属机身
   沉坑底衬 → 轮盘 → 中心按钮 三层立体结构
   =========================================== */
.ipod-wheel-wrap {
  position: absolute;
  top: 52%;
  left: 50%;
  transform: translateX(-50%);
  width: 50%;
  z-index: 5;
}

.ipod-wheel {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 50%;
  position: relative;
  /* 白色陶瓷 — 微凸渐变 */
  background: radial-gradient(circle at 50% 50%,
    #fcfcfc 0%, #f6f6f6 30%, #efefef 58%, #e8e8e8 78%, #e4e4e4 100%);
  box-shadow:
    /* 外圈立体斜面 — 合并为单层 */
    0 0 0 3rpx rgba(200,200,200,0.42),
    /* 凸面顶部高光 */
    inset 0 2rpx 3rpx rgba(255,255,255,0.80),
    /* 凸面底部渐暗 */
    inset 0 -4rpx 12rpx rgba(0,0,0,0.04),
    /* 凸面整体微暗 */
    inset 0 0 10rpx rgba(0,0,0,0.02);
}

/* 表面柔光 — 陶瓷哑光漫反射 */
.ipod-wheel::before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  border-radius: 50%;
  pointer-events: none;
  z-index: 1;
  background: radial-gradient(ellipse 52% 36% at 48% 38%,
    rgba(255,255,255,0.40) 0%,
    rgba(255,255,255,0.14) 38%,
    transparent 72%);
}

/* 内圈刻痕 — 已移除 */
.ipod-wheel-ring {
  display: none;
}

/* 中心按钮 — 白色陶瓷轻微凹陷 */
.ipod-wheel-center {
  width: 36%;
  height: 36%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  z-index: 3;
  box-shadow:
    /* ① 远距投影 — 中心按钮悬浮于轮盘之上 */
    0 30rpx 90rpx rgba(0,0,0,0.28),
    /* ② 近距投影 — 加强立体感 */
    0 8rpx 28rpx rgba(0,0,0,0.16),
    /* ③ 顶部倒角高光 — 主光击中弧顶的镜面反射 */
    inset 0 4rpx 3rpx rgba(255,255,255,0.85),
    /* ④ 底部+侧面暗面 — 背光侧金属厚度（合并底/左/右） */
    inset 0 -4rpx 6rpx rgba(0,0,0,0.26),
    /* ⑤ 边缘台阶环 — 金属中框微凸起 */
    0 0 0 2rpx rgba(160,160,160,0.28);
}

/* 中心按钮表面柔光 — 双光源金属高光 */
.ipod-wheel-center::before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  border-radius: 50%;
  pointer-events: none;
  background:
    /* 左上主光源镜面反射 — 锐利高光带 */
    linear-gradient(140deg,
      rgba(255,255,255,0.60) 0%,
      rgba(255,255,255,0.28) 6%,
      rgba(255,255,255,0.08) 14%,
      transparent 24%),
    /* 底部地面反弹光 */
    radial-gradient(ellipse 60% 28% at 50% 90%,
      rgba(255,255,255,0.20) 0%,
      transparent 70%),
    /* 右下角暗面 */
    linear-gradient(320deg,
      rgba(0,0,0,0.06) 0%,
      transparent 30%);
}

