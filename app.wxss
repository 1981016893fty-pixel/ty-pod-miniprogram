  font-size: 19rpx;
  color: rgba(0,0,0,0.50);
  font-weight: 600;
  letter-spacing: -1rpx;
  white-space: nowrap;
  z-index: 10;
  pointer-events: auto;
  transition: transform 0.12s ease, background 0.12s ease;
}
.ipod-wheel-btn:active {
  transform: translateX(-50%) scale(0.92);
  background: rgba(0,0,0,0.06);
}
.ipod-wheel-btn.top    { top: 12%;  left: 50%; transform: translateX(-50%); }
.ipod-wheel-btn.bottom { bottom: 12%; left: 50%; transform: translateX(-50%); font-size: 17rpx; letter-spacing: 0; }
.ipod-wheel-btn.left   { left: 12%;  top: 50%; transform: translateY(-50%); }
.ipod-wheel-btn.right  { right: 12%; top: 50%; transform: translateY(-50%); }
.ipod-wheel-btn.left:active  { transform: translateY(-50%) scale(0.92); }
.ipod-wheel-btn.right:active { transform: translateY(-50%) scale(0.92); }
.ipod-wheel-btn.bottom:active{ transform: translateX(-50%) scale(0.92); }

