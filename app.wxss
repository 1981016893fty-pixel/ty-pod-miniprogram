/* 四向按钮 */
.ipod-wheel-btn {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60rpx;
  min-height: 60rpx;
  padding: 6rpx 12rpx;
  border-radius: 50%;
