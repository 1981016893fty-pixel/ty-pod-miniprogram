/* ===========================================
   屏幕 — 浅色液态玻璃（浓郁霓虹渐变）
   =========================================== */
.ipod-screen {
  position: absolute;
  top: 5.5%;
  left: 7%;
  right: 7%;
  height: 43%;
  z-index: 2;
  /* — 液态玻璃基底：三色霓虹交融（⭐ 底层密度提升，供 backdrop-filter 模糊用）— */
  background:
    /* ① 大范围紫色光晕 */
    radial-gradient(ellipse 88% 82% at 22% 18%, rgba(178,140,248,0.48) 0%, rgba(160,108,232,0.30) 18%, rgba(145,95,220,0.14) 44%, transparent 66%),
    /* ② 大范围粉色光晕 */
    radial-gradient(ellipse 82% 78% at 74% 74%, rgba(255,108,172,0.42) 0%, rgba(240,88,158,0.28) 20%, rgba(228,78,148,0.12) 48%, transparent 70%),
    /* ③ 蓝色光晕 */
    radial-gradient(ellipse 68% 62% at 48% 42%, rgba(88,200,245,0.30) 0%, rgba(72,185,230,0.16) 33%, rgba(58,170,218,0.07) 58%, transparent 78%),
    /* ④ 全屏紫粉渐变基底 */
    radial-gradient(ellipse 100% 90% at 50% 50%, rgba(178,140,248,0.17) 0%, rgba(255,108,172,0.11) 38%, rgba(88,200,245,0.09) 68%, transparent 100%),
    /* ⑤ 液态玻璃乳白底色 */
    linear-gradient(170deg,
      #f4f0fd 0%, #f1ecfa 6%, #efe9f7 14%,
      #ede7f5 24%, #ece6f4 38%, #eee8f6 52%,
      #f0eaf8 64%, #f1ecfa 76%, #f3effc 90%, #f4f0fd 100%);
  border-radius: 10rpx;
  overflow: hidden;
  /* — 厚玻璃边缘：融合霓虹色散，无硬边框 — */
  box-shadow:
    inset 0 2rpx 1rpx rgba(255,255,255,0.60),
    inset 0 -3rpx 2rpx rgba(20,10,40,0.08),
    inset 2rpx 0 1rpx rgba(255,255,255,0.30),
    inset -2rpx 0 1rpx rgba(20,10,40,0.04),
    inset 0 0 32rpx rgba(178,140,248,0.18),
    inset 0 0 24rpx rgba(255,108,172,0.10),
    inset 0 0 16rpx rgba(88,200,245,0.08),
    0 0 20rpx rgba(178,140,248,0.22),
    0 0 40rpx rgba(178,140,248,0.10),
    0 0 60rpx rgba(255,108,172,0.06);
}

/* ===========================================
   凯斯哈林涂鸦背景层（页面级 — 在 iPod 机身后面）
   =========================================== */
.kh-bg-layer {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
  overflow: hidden;
}
.kh-bg-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(1.05);
  filter: blur(20px);
  transition:
    opacity 3s ease-in-out,
    filter 3s ease-in-out,
    transform 3s ease-in-out;
}
.kh-bg-img.active {
  opacity: 1;
  transform: scale(1);
  filter: blur(0);
}

/* 屏幕表面 — 液态玻璃镜面反射（静态） */
.ipod-screen::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 3;
  pointer-events: none;
  border-radius: 10rpx;
  background:
    /* ① 底部液态三色融合反射 */
    radial-gradient(ellipse 75% 24% at 48% 94%, rgba(178,140,248,0.22) 0%, rgba(200,130,220,0.15) 20%, rgba(230,118,190,0.11) 45%, rgba(88,200,245,0.08) 68%, transparent 88%),
    /* ② 右侧柔和高光 */
    radial-gradient(ellipse 18% 52% at 93% 48%, rgba(255,255,255,0.14) 0%, transparent 68%);
}

/* 屏幕边缘 — 液态玻璃色散折射（⭐ 实时呼吸动画）*/
.ipod-screen::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 4;
  pointer-events: none;
  border-radius: 10rpx;
  will-change: opacity;
  animation: edgeBreathe 7s ease-in-out infinite;
  background:
    /* ① 顶部亮线 — 减弱，避免标题栏区域过亮 */
    linear-gradient(180deg, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0.06) 1.5%, transparent 4%),
    /* ② 底部暗线 */
    linear-gradient(0deg, rgba(20,10,40,0.12) 0%, rgba(20,10,40,0.04) 1.5%, transparent 4%),
    /* ③ 左边色散 — 青→紫渐变 */
    linear-gradient(90deg, rgba(88,200,245,0.34) 0%, rgba(88,200,245,0.16) 2%, rgba(178,140,248,0.08) 5%, transparent 10%),
    /* ④ 右边色散 — 品红→紫渐变 */
    linear-gradient(270deg, rgba(255,108,172,0.34) 0%, rgba(255,108,172,0.16) 2%, rgba(178,140,248,0.08) 5%, transparent 10%),
    /* ⑤ 四角融合色散 — 两两交融 */
    radial-gradient(ellipse 16% 14% at 0% 0%, rgba(88,200,245,0.42) 0%, rgba(140,165,240,0.20) 35%, rgba(178,140,248,0.08) 55%, transparent 72%),
    radial-gradient(ellipse 16% 14% at 100% 0%, rgba(178,140,248,0.28) 0%, rgba(210,120,205,0.18) 38%, rgba(255,108,172,0.08) 55%, transparent 72%),
    radial-gradient(ellipse 16% 14% at 0% 100%, rgba(178,140,248,0.38) 0%, rgba(140,165,240,0.18) 38%, rgba(88,200,245,0.08) 55%, transparent 72%),
    radial-gradient(ellipse 16% 14% at 100% 100%, rgba(255,108,172,0.40) 0%, rgba(210,120,205,0.20) 38%, rgba(178,140,248,0.08) 55%, transparent 72%);
}

/* 屏幕内容层 — 真实磨砂玻璃覆盖（backdrop-filter 真模糊）*/
.ipod-screen-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
  /* ⭐ 移除 overflow:hidden — 不再裁剪流动光晕伪元素 */
  /* ⭐ 核心：增强液态玻璃 — 更模糊 + 微对比度增强厚度感 */
  backdrop-filter: blur(14px) saturate(1.8) contrast(1.04) brightness(1.04);
  -webkit-backdrop-filter: blur(14px) saturate(1.8) contrast(1.04) brightness(1.04);
  /* 玻璃微乳白 tint + 内层深度光晕 — 顶部不加白，保持全屏均匀 */
  background:
    radial-gradient(ellipse 85% 65% at 50% 50%, rgba(178,140,248,0.08) 0%, transparent 70%);
  /* 玻璃内边高光 + 微厚度阴影 */
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.28),
    inset 0 -1rpx 2rpx rgba(20,10,40,0.04);
}

/* ═══ 屏幕底色渐变 — 跟随机身颜色（替换紫/粉/蓝三色光晕为对应色） ═══ */
