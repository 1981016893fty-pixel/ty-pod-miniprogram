/* ===========================================
   ⭐ 霓虹色块实时流动动画 — 熔岩灯效果
   =========================================== */

/* ① 紫蓝色块 — 大范围橢圆漂移 + 呼吸缩放，8s 周期 */
@keyframes blobDriftPurple {
  0%, 100% {
    opacity: 0.72;
    transform: translate(0, 0) scale(1);
  }
  20% {
    opacity: 0.98;
    transform: translate(18%, -14%) scale(1.30);
  }
  40% {
    opacity: 0.55;
    transform: translate(-10%, 16%) scale(0.82);
  }
  60% {
    opacity: 0.92;
    transform: translate(-16%, 6%) scale(1.18);
  }
  80% {
    opacity: 0.78;
    transform: translate(8%, -8%) scale(1.08);
  }
}

/* ② 青色色块 — 反向大范围漂移 + 交错呼吸，10s 周期 */
@keyframes blobDriftPink {
  0%, 100% {
    opacity: 0.67;
    transform: translate(0, 0) scale(1);
  }
  25% {
    opacity: 0.95;
    transform: translate(-20%, 12%) scale(1.28);
  }
  50% {
    opacity: 0.50;
    transform: translate(12%, -18%) scale(0.78);
  }
  75% {
    opacity: 0.88;
    transform: translate(-8%, 6%) scale(1.15);
  }
}

/* ③ 琥珀色块 — 斜向漂移 + 呼吸缩放，12s 周期 */
@keyframes blobDriftAmber {
  0%, 100% {
    opacity: 0.62;
    transform: translate(0, 0) scale(1);
  }
  20% {
    opacity: 0.90;
    transform: translate(-14%, -10%) scale(1.22);
  }
  40% {
    opacity: 0.48;
    transform: translate(16%, 14%) scale(0.85);
  }
  60% {
    opacity: 0.82;
    transform: translate(10%, -16%) scale(1.12);
  }
  80% {
    opacity: 0.58;
    transform: translate(-12%, 8%) scale(0.95);
  }
}

/* ④ 深色霓虹（深蓝紫）— 大弧线漂移 + 缓慢呼吸，14s 周期 */
@keyframes blobDriftDeep {
  0%, 100% {
    opacity: 0.50;
    transform: translate(0, 0) scale(1);
  }
  25% {
    opacity: 0.82;
    transform: translate(18%, -22%) scale(1.28);
  }
  50% {
    opacity: 0.35;
    transform: translate(-20%, 16%) scale(0.80);
  }
  75% {
    opacity: 0.70;
    transform: translate(-8%, -18%) scale(1.15);
  }
}

/* ③ 屏幕边缘棱角色散呼吸，7s 周期 */
@keyframes edgeBreathe {
  0%, 100% { opacity: 0.78; }
  35%      { opacity: 1.0; }
  65%      { opacity: 0.60; }
}

