  to   { opacity: 1; }
}

/* 模糊专辑封面背景 — 提供主题色基底 */
.full-lyric-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(80rpx) saturate(2.8);
  transform: scale(1.4);
}

/* 色块流动感 — 动态渐变球 */
.full-lyric-flow {
  position: absolute;
  border-radius: 50%;
  filter: blur(45rpx);
  mix-blend-mode: screen;
  will-change: transform, opacity;
}
.flow-1 {
  width: 800rpx; height: 800rpx;
  background: radial-gradient(circle, rgba(255,40,120,0.70) 0%, rgba(255,40,120,0.20) 40%, transparent 70%);
  top: -15%; left: -20%;
  opacity: 0.72;
  animation: flowMove1 4s ease-in-out infinite alternate;
}
.flow-2 {
  width: 750rpx; height: 750rpx;
  background: radial-gradient(circle, rgba(30,140,255,0.65) 0%, rgba(30,140,255,0.18) 40%, transparent 70%);
  bottom: -18%; right: -22%;
  opacity: 0.68;
  animation: flowMove2 5s ease-in-out infinite alternate;
}
.flow-3 {
  width: 680rpx; height: 680rpx;
  background: radial-gradient(circle, rgba(160,60,255,0.60) 0%, rgba(160,60,255,0.16) 40%, transparent 70%);
  top: 25%; left: 20%;
  opacity: 0.65;
  animation: flowMove3 4.5s ease-in-out infinite alternate;
}
.flow-4 {
  width: 620rpx; height: 620rpx;
  background: radial-gradient(circle, rgba(255,180,30,0.55) 0%, rgba(255,180,30,0.14) 40%, transparent 70%);
  top: 50%; right: 10%;
  opacity: 0.60;
  animation: flowMove4 3.5s ease-in-out infinite alternate;
}
.flow-5 {
  width: 700rpx; height: 700rpx;
  background: radial-gradient(circle, rgba(40,255,180,0.50) 0%, rgba(40,255,180,0.12) 40%, transparent 70%);
  bottom: 15%; left: -10%;
  opacity: 0.58;
  animation: flowMove5 5.5s ease-in-out infinite alternate;
}
@keyframes flowMove1 {
  0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
  33%  { transform: translate(180rpx, 280rpx) scale(1.6) rotate(30deg); }
  66%  { transform: translate(320rpx, 80rpx) scale(1.2) rotate(-25deg); }
  100% { transform: translate(150rpx, 350rpx) scale(1.5) rotate(20deg); }
}
@keyframes flowMove2 {
  0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
  33%  { transform: translate(-200rpx, -180rpx) scale(1.5) rotate(-35deg); }
  66%  { transform: translate(-100rpx, -320rpx) scale(1.3) rotate(25deg); }
  100% { transform: translate(-280rpx, -100rpx) scale(1.6) rotate(-20deg); }
}
@keyframes flowMove3 {
  0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
  33%  { transform: translate(200rpx, -250rpx) scale(1.7) rotate(40deg); }
  66%  { transform: translate(-150rpx, -100rpx) scale(1.2) rotate(-30deg); }
  100% { transform: translate(180rpx, 200rpx) scale(1.5) rotate(15deg); }
}
@keyframes flowMove4 {
  0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
  50%  { transform: translate(-220rpx, -180rpx) scale(1.8) rotate(45deg); }
  100% { transform: translate(160rpx, -280rpx) scale(1.3) rotate(-35deg); }
}
@keyframes flowMove5 {
  0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
  50%  { transform: translate(280rpx, -200rpx) scale(1.6) rotate(-40deg); }
  100% { transform: translate(-200rpx, 160rpx) scale(1.4) rotate(30deg); }
}

/* 遮罩层 — 压低透明度遮挡底层内容 */
.full-lyric-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(8,8,14,0.38);
}

/* 内容区 — 液态玻璃 */
.full-lyric-content {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 36rpx;
  box-sizing: border-box;
}

/* 顶部栏 */
.full-lyric-header {
  display: flex;
  align-items: center;
  padding-top: 70rpx;
  padding-bottom: 16rpx;
  flex-shrink: 0;
}
.full-lyric-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  backdrop-filter: blur(20rpx) saturate(1.8);
  -webkit-backdrop-filter: blur(20rpx) saturate(1.8);
}
.full-lyric-close-icon {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}
.full-lyric-close-icon::before,
.full-lyric-close-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 20rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.80);
  border-radius: 1rpx;
}
.full-lyric-close-icon::before {
  transform: translateY(-50%) rotate(45deg);
}
.full-lyric-close-icon::after {
  transform: translateY(-50%) rotate(-45deg);
}
.full-lyric-song-info {
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.full-lyric-song-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.25);
}
.full-lyric-song-artist {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  margin-top: 2rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.15);
}

/* 中间区域：左专辑 + 右歌词 */
.full-lyric-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 0;
}

/* 左侧：专辑封面 2.5D */
.full-lyric-album-side {
  width: 40%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  perspective: 800rpx;
}
.full-lyric-album-3d {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  transform: rotateY(18deg) rotateX(6deg);
  transform-style: preserve-3d;
  box-shadow:
    12rpx 16rpx 40rpx rgba(0,0,0,0.45),
    4rpx 6rpx 16rpx rgba(0,0,0,0.25);
  border-radius: 16rpx;
  overflow: hidden;
  animation: albumFloat 4s ease-in-out infinite alternate;
}
@keyframes albumFloat {
  from { transform: rotateY(18deg) rotateX(6deg) translateY(0); }
  to   { transform: rotateY(15deg) rotateX(4deg) translateY(-10rpx); }
}
.full-lyric-album-cover {
  width: 100%;
  height: 100%;
  display: block;
}
/* 专辑封面表面高光 — 模拟 2.5D 玻璃面 */
.full-lyric-album-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    225deg,
    rgba(255,255,255,0.25) 0%,
    rgba(255,255,255,0.05) 30%,
    transparent 50%,
    transparent 70%,
    rgba(255,255,255,0.08) 100%
  );
  pointer-events: none;
  border-radius: 16rpx;
}
/* 倒影 */
.full-lyric-album-reflection {
  width: 260rpx;
  height: 80rpx;
  margin-top: 8rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, transparent 80%);
  border-radius: 16rpx 16rpx 50% 50%;
  filter: blur(10rpx);
  transform: scaleY(-1);
  opacity: 0.4;
}

/* 右侧：歌词滚动区 */
.full-lyric-lyric-side {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding-left: 24rpx;
}
.full-lyric-scroll {
  flex: 1;
  overflow: hidden;
}
.full-lyric-list {
  padding: 500rpx 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.full-lyric-line {
  font-size: 28rpx;
  color: rgba(255,255,255,0.20);
  text-align: left;
  line-height: 1.6;
  padding: 10rpx 0;
  /* 慢慢淡入淡出：0.5s 缓动，距离变化时温柔过渡 */
  transition: color 0.5s ease, opacity 0.5s ease, transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1), text-shadow 0.5s ease;
  max-width: 100%;
  word-break: break-word;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.20);
  transform-origin: left center;
  will-change: transform, opacity;
  display: flex;
  flex-direction: column;
  opacity: 0.15;
}
/* 默认/远处的句子：基本不显示，慢慢淡出 */
.full-lyric-line--far {
  color: rgba(255,255,255,0.20);
  opacity: 0.20;
}
/* 距离 3-6 行：屏幕中段可见区域，保持正常可见度 */
.full-lyric-line--mid {
  color: rgba(255,255,255,0.45);
  opacity: 0.45;
}
/* 距离 1-2 行（下一句/上一句）：屏幕中央可见区，清晰可见 */
.full-lyric-line--near {
  color: rgba(255,255,255,0.75);
  opacity: 0.75;
}
/* 当前行：最亮，放大平移，柔和发光 */
.full-lyric-line--cur {
  color: #ffffff;
  font-weight: 700;
  opacity: 1;
  text-shadow:
    0 0 16rpx rgba(255,255,255,0.40),
    0 0 24rpx rgba(255,255,255,0.15),
    0 1rpx 6rpx rgba(0,0,0,0.25);
  transform: translateX(6rpx) scale(1.15);
}
.full-lyric-line .full-lyric-line-text {
  display: block;
}
.full-lyric-line .full-lyric-line-tr {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.20);
  line-height: 1.5;
  margin-top: 2rpx;
  transition: color 0.5s ease, opacity 0.5s ease;
}
/* 翻译行：跟随主行同步淡入淡出 */
.full-lyric-line--far .full-lyric-line-tr { color: rgba(255,255,255,0.20); opacity: 0.20; }
.full-lyric-line--mid .full-lyric-line-tr { color: rgba(255,255,255,0.40); opacity: 0.45; }
.full-lyric-line--near .full-lyric-line-tr { color: rgba(255,255,255,0.65); opacity: 0.75; }
.full-lyric-line--cur .full-lyric-line-tr { color: rgba(255,255,255,0.60); opacity: 1; }
.full-lyric-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: rgba(255,255,255,0.55);
  font-size: 26rpx;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.15);
}

/* 底部进度条 + 左右音波 */
.full-lyric-footer {
  display: flex;
  align-items: center;
  padding: 0 4rpx 50rpx;
  flex-shrink: 0;
  gap: 14rpx;
}

/* 音波条容器 — 横向均布，自动均匀占据左右空间 */
.full-lyric-wave {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  flex: 1;
  min-width: 0;
}
.full-lyric-wave-left  { flex-direction: row-reverse; }   /* 视觉上从中心向左散开 */
.full-lyric-wave-right { flex-direction: row; }

/* 单根音波条 */
.wave-bar {
  width: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(180deg, var(--tc-bright, rgba(255,60,140,0.95)) 0%, var(--tc, rgba(150,80,255,0.85)) 60%, var(--tc-soft, rgba(50,150,255,0.70)) 100%);
  box-shadow: 0 0 6rpx var(--tc, rgba(255,80,180,0.45));
  transition: height 0.18s cubic-bezier(0.25, 0.1, 0.25, 1), opacity 0.18s ease;
  will-change: height, opacity;
}

/* 中间进度条容器 */
.full-lyric-progress-wrap {
  flex: 0 0 auto;
  width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.full-lyric-progress-bar {
  position: relative;
  width: 100%;
  height: 4rpx;
  background: rgba(255,255,255,0.10);
  border-radius: 2rpx;
  overflow: visible;
}
.full-lyric-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--tc-bright, rgba(255,60,140,0.85)) 0%, var(--tc, rgba(150,80,255,0.85)) 50%, var(--tc-soft, rgba(50,150,255,0.85)) 100%);
  border-radius: 2rpx;
  transition: width 0.3s linear;
  box-shadow: 0 0 12rpx var(--tc, rgba(255,80,180,0.50));
}
.full-lyric-progress-dot {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--tc-bright, rgba(255,120,180,0.95)) 0%, var(--tc, rgba(150,80,255,0.90)) 100%);
  box-shadow: 0 0 14rpx var(--tc, rgba(255,80,180,0.60)), 0 0 6rpx var(--tc-bright, rgba(150,80,255,0.40));
  transition: left 0.3s linear;
}
.full-lyric-time {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
.full-lyric-time text {
  font-size: 18rpx;
  color: rgba(255,255,255,0.55);
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.15);
}

/* ===========================================
   搜索空状态 — 历史记录 + 热门歌手
   =========================================== */
.ipod-search-idle {
  padding: 8rpx 4rpx 16rpx;
}
.ipod-search-section {
  margin-bottom: 20rpx;
}
.ipod-search-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 8rpx 10rpx;
}
.ipod-search-section-title {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  letter-spacing: 1rpx;
}
.ipod-search-section-sub {
  font-size: 16rpx;
  color: rgba(255,255,255,0.38);
}
.ipod-search-section-clear {
  padding: 4rpx 12rpx;
  font-size: 17rpx;
  color: rgba(255,255,255,0.55);
  border: 0.5rpx solid rgba(255,255,255,0.20);
  border-radius: 16rpx;
  background: rgba(255,255,255,0.06);
}
.ipod-search-section-clear:active {
  background: rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.85);
}

/* 历史项 — 横向一行一条 */
.ipod-search-history-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.ipod-search-history-item {
  display: flex;
  align-items: center;
  height: 56rpx;
  padding: 0 12rpx 0 14rpx;
  border-radius: 10rpx;
  background: rgba(255,255,255,0.05);
  border: 0.5rpx solid rgba(255,255,255,0.08);
}
.ipod-search-history-item:active {
  background: rgba(255,255,255,0.14);
}
.ipod-search-history-icon {
  font-size: 18rpx;
  color: rgba(255,255,255,0.40);
  margin-right: 10rpx;
  flex-shrink: 0;
}
.ipod-search-history-text {
  flex: 1;
  font-size: 21rpx;
  color: rgba(255,255,255,0.82);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ipod-search-history-remove {
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 6rpx;
}
.ipod-search-history-remove:active {
  background: rgba(255,108,172,0.45);
  color: #ffffff;
}

/* 热门歌手 — 网格标签 */
.ipod-hot-artists {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 0 4rpx;
}
.ipod-hot-artist-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 48rpx;
  padding: 0 18rpx;
  background: linear-gradient(135deg, rgba(178,140,248,0.20) 0%, rgba(255,108,172,0.18) 100%);
  border: 0.5rpx solid rgba(255,255,255,0.18);
  border-radius: 24rpx;
  box-shadow:
    inset 0 1rpx 0.5rpx rgba(255,255,255,0.20),
    inset 0 -0.5rpx 1rpx rgba(20,10,40,0.06);
}
.ipod-hot-artist-tag:active {
  background: linear-gradient(135deg, rgba(178,140,248,0.40) 0%, rgba(255,108,172,0.36) 100%);
  transform: scale(0.96);
  transition: transform 0.08s ease-out;
}
.ipod-hot-artist-emoji {
  font-size: 19rpx;
  line-height: 1;
}
.ipod-hot-artist-name {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.92);
  letter-spacing: 0.5rpx;
}